{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "gotPuzzled — Final",
    "description": "Complete REST API collection for the gotPuzzled puzzle application.\n\nAll routes are prefixed with /api. Authentication is header-based:\n  x-user-id   — the numeric userId of the caller\n  x-user-role — 'player' | 'admin' | 'manager'\n\nGroups:\n  Auth     — login / logout\n  Users    — CRUD for user accounts\n  Scores   — personal and global leaderboards\n  Images   — Pexels image generation for puzzles\n  AI       — Gemini topic-extraction for image search\n  Settings — current-user profile preferences",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "description": "POST /api/auth/login and POST /api/auth/logout.\nNo tokens or sessions — the server returns userId + userRole which the frontend stores in React state.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"max@mail.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "login"]
            },
            "description": "Verify email + password. Returns { userId, userRole } on success.\n\nExpected response (200):\n{\n  \"success\": true,\n  \"data\": { \"message\": \"Login successful\", \"user\": { \"userId\": 1, \"userRole\": \"player\" } },\n  \"error\": null\n}"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "logout"]
            },
            "description": "Stateless logout acknowledgement — no server-side session to clear.\n\nExpected response (200):\n{\n  \"success\": true,\n  \"data\": { \"message\": \"Successfully logged out\" },\n  \"error\": null\n}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "description": "CRUD endpoints for user accounts.\n\nGET /me and GET / require role-based headers.\nPOST / (create) is open — used by the sign-up flow.",
      "item": [
        {
          "name": "Get My Profile (me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/users/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users", "me"]
            },
            "description": "Fetch the logged-in user's full profile. The user ID is read from the x-user-id header (no URL param needed).\n\nAllowed roles: player, admin"
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "2",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "admin",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users"]
            },
            "description": "Return every user in the database.\n\nAllowed roles: admin only"
          },
          "response": []
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users", "1"]
            },
            "description": "Fetch a single user by their numeric ID in the URL.\n\nAllowed roles: admin, player"
          },
          "response": []
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Max\",\n  \"lastName\": \"Black\",\n  \"userRole\": \"player\",\n  \"email\": \"max@mail.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users"]
            },
            "description": "Register a new user account. Also used by the frontend sign-up flow.\nRequired fields: firstName, lastName, userRole, email, password.\nuserRole must be one of: 'player', 'admin', 'manager'.\n\nExpected response (201):\n{\n  \"success\": true,\n  \"data\": { \"userId\": 5 },\n  \"error\": null\n}"
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alicia\",\n  \"lastName\": \"Cohen\",\n  \"email\": \"alicia@example.com\",\n  \"theme\": \"dark\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users", "1"]
            },
            "description": "Update a user's profile. The URL :id and the x-user-id header must match for a player; admins may update any user.\nRequired fields: firstName, lastName. Optional: email, theme.\n\nAllowed roles: admin, player, manager"
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-user-id",
                "value": "5",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "admin",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/users/5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users", "5"]
            },
            "description": "Remove a user and cascade-delete all of their score records.\nReturns the count of deleted scores for transparency.\n\nAllowed roles: admin, player"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Scores",
      "description": "Endpoints for personal leaderboards, global leaderboards, and dashboard stats.\n\nScore times are stored and submitted in HH:MM:SS format (e.g. \"00:03:42\").\nThe POST endpoint returns 400 ALREADY_EXISTS when a record for the same user/pieces/rounds combo exists — the client should fall back to PUT.",
      "item": [
        {
          "name": "Get All Scores (Global Leaderboard)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "2",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "admin",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/scores",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "scores"]
            },
            "description": "Return every score in the database joined with owner info.\n\nAllowed roles: admin only"
          },
          "response": []
        },
        {
          "name": "Get Scores By User ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/scores/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "scores", "1"]
            },
            "description": "Return all scores for a specific user (their personal leaderboard).\n\nAllowed roles: admin, player"
          },
          "response": []
        },
        {
          "name": "Get Specific Score (User + Pieces + Rounds)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/scores/1/9/3",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "scores", "1", "9", "3"]
            },
            "description": "Look up one exact score record: user 1, 9 pieces, 3 rounds.\nURL pattern: /api/scores/:id/:pieces/:rounds\n\nAllowed roles: admin, player"
          },
          "response": []
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/scores/stats/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "scores", "stats", "1"]
            },
            "description": "Return aggregated stats for the dashboard: topPieces, topRounds, fastestScore.\nReturns 404 (not an error) when the user has no scores yet.\n\nExpected response (200):\n{\n  \"success\": true,\n  \"data\": { \"topPieces\": 25, \"topRounds\": 5, \"fastestScore\": \"00:02:18\" },\n  \"error\": null\n}"
          },
          "response": []
        },
        {
          "name": "Create Score",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pieces\": 25,\n  \"rounds\": 3,\n  \"score\": \"00:04:32\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/scores/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "scores", "1"]
            },
            "description": "Record a new score after a game session.\nRequired: pieces (integer), rounds (integer), score (HH:MM:SS string).\n\nReturns 400 ALREADY_EXISTS if a record for this user/pieces/rounds combo already exists — use PUT to update it instead.\n\nAllowed roles: admin, player"
          },
          "response": []
        },
        {
          "name": "Update Score",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "x-user-id",
                "value": "1",
                "type": "text"
              },
              {
                "key": "x-user-role",
                "value": "player",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pieces\": 25,\n  \"rounds\": 3,\n  \"score\": \"00:03:17\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/scores/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "scores", "1"]
            },
            "description": "Update an existing score — only overwrites if the new time is strictly better (lower).\nRequired: pieces (integer), rounds (integer), score (HH:MM:SS string).\n\nResponse includes isNewRecord: true if the time was improved.\n\nAllowed roles: admin, manager, player"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Images",
      "description": "Wraps the Pexels API so the PEXELS_API_KEY stays server-side.\nReturns an array of direct image URLs ready to use as puzzle backgrounds.",
      "item": [
        {
          "name": "Generate Images",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/images/generate?topic=sunset mountains&count=3",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "images", "generate"],
              "query": [
                {
                  "key": "topic",
                  "value": "sunset mountains",
                  "description": "Image search keyword (required)"
                },
                {
                  "key": "count",
                  "value": "3",
                  "description": "Number of images to return (1–20, default 5)"
                }
              ]
            },
            "description": "Fetch random Pexels images for a given topic keyword.\n\nQuery params:\n  topic  {string} — required; the image search keyword\n  count  {number} — optional (default 5); how many image URLs to return\n\nExpected response (200):\n{\n  \"success\": true,\n  \"data\": [\n    \"https://images.pexels.com/...\",\n    \"https://images.pexels.com/...\",\n    \"https://images.pexels.com/...\"\n  ],\n  \"error\": null\n}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI",
      "description": "Gemini Flash AI endpoint. Converts a user's free-text description into a short, clean image search keyword.\n\nThe Gemini API key is stored server-side and never exposed to the browser.",
      "item": [
        {
          "name": "Extract Topic",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"I want a puzzle about a beautiful forest in autumn with red and orange leaves\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/ai/extract",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "ai", "extract"]
            },
            "description": "Send a free-text description; receive a short refined keyword suitable for image search.\n\nRequired body field: text (non-empty string)\n\nExpected response (200):\n{\n  \"success\": true,\n  \"data\": \"autumn forest\",\n  \"error\": null\n}"
          },
          "response": []
        }
      ]
    },
